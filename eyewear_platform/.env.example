# AWS Configuration
# Get credentials from AWS IAM console: https://console.aws.amazon.com/iam/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here

# AWS Bedrock Model Configuration
# See: https://docs.aws.amazon.com/bedrock/latest/userguide/
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Bedrock Bearer Token (if using API token auth)
# Leave empty if using IAM credentials above
BEDROCK_BEARER_TOKEN=

# Set to 'true' to use mock/offline Bedrock responses (for testing without AWS access)
MOCK_BEDROCK=false

# Data and Model Paths
DATA_DIR=data/synthetic
MODEL_DIR=models/artifacts

# Logging
LOG_LEVEL=INFO

# Forecasting Parameters
FORECAST_HORIZON_DAYS=90

# Recommendation Parameters
SIMILARITY_TOP_N=5
REORDER_SAFETY_STOCK_DAYS=30
